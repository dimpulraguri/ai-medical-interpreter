NODE_ENV=development
PORT=8090
CORS_ORIGIN=http://localhost:3000

# Use `memory` to run without installing MongoDB (dev only), or a real URI.
MONGODB_URI=memory

# Use long random secrets (>= 32 chars). Example generator:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret________________________________
JWT_REFRESH_SECRET=change_me_refresh_secret______________________________
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30

# 32 bytes, base64. Example generator:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY_BASE64=change_me_base64_32_bytes______________________

OPENAI_API_KEY=your_openai_api_key
# Pick a model you have access to
OPENAI_MODEL=gpt-4.1-mini
# AI_MODE:
# - openai: use OpenAI API (default)
# - huggingface: use HuggingFace Inference API (works without OpenAI billing)
# - demo: no external AI calls (works without billing/quota)
# - off: disable AI endpoints (returns 503)
AI_MODE=openai
HF_API_KEY=
HF_MODEL=google/flan-t5-large

# Upload storage: local (default) or s3 (recommended for production)
STORAGE_DRIVER=local
# Production guard: by default, production requires STORAGE_DRIVER=s3.
# Set this to true only if you understand the risk of losing files on redeploy.
ALLOW_LOCAL_STORAGE_IN_PROD=false
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional for S3-compatible providers (MinIO/R2/etc)
S3_ENDPOINT=

# If a PDF is scanned and has little/no text, OCR the first N pages
PDF_OCR_MAX_PAGES=3

# Optional: email reminders
SENDGRID_API_KEY=
EMAIL_FROM=

# Optional: push notifications via FCM.
# Paste the service account JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: bootstrap admin role (comma-separated emails)
ADMIN_EMAILS=dimpulraguri@gmail.com
